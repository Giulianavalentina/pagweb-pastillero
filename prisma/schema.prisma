generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Alarm {
  id        Int      @id @default(autoincrement())
  time      String
  medicamento String // Nuevo campo separado
  dosis     String?  // Nuevo campo opcional
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  histories History[]
}

model History {
  id        Int      @id @default(autoincrement())
  alarmId   Int
  action    String
  createdAt DateTime @default(now())
  alarm     Alarm    @relation(fields: [alarmId], references: [id])
}